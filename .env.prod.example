# Copy to `.env` next to docker-compose.prod.yml and fill in real secrets.
# Never commit the filled-in .env.

ORACLE_SYS_PASSWORD=change_me_strong_sys_password
DATABASE_USER=aiheatmap
DATABASE_PASSWORD=change_me_strong_app_password
DATABASE_NAME=XEPDB1

JWT_SECRET=change_me_long_random_secret
CORS_ORIGIN=https://your-domain.example

# Optional integrations (leave blank to disable)
ALPHA_VANTAGE_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.example
