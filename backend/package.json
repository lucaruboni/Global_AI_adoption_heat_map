{
  "name": "@ai-heatmap/backend",
  "version": "0.1.0",
  "description": "Global AI Adoption Heat Map - Backend API",
  "main": "dist/backend/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx src/database/seed.ts",
    "db:seed:stocks": "tsx src/database/seed-stocks.ts",
    "prebuild": "npm run lint && npm run typecheck"
  },
  "keywords": [
    "ai",
    "adoption",
    "heatmap",
    "global",
    "analytics"
  ],
  "author": "Luca Ruboni <lucaruboni@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.17",
    "oracledb": "^6.2.0",
    "redis": "^4.6.11",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.11",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2"
  }
}
